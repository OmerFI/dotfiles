{
    // VsCode User Settings (settings.json)
    //
    // Workaround: built-in Copilot Chat's CLI/Claude "agent sessions" integration
    // freezes the whole extension host for 60-430s at startup on WSL
    // (first listSessions call blocks the event loop while loading its SDK).
    // Does NOT affect Copilot inline completions.
    // Upstream: https://github.com/microsoft/vscode/issues/319710
    "github.copilot.chat.claudeAgent.enabled": false,
    "github.copilot.chat.cli.showExternalSessions": false,
    "chat.viewSessions.enabled": false,
    "window.commandCenter": true,
    "workbench.iconTheme": "material-icon-theme",
    "workbench.colorTheme": "GitHub Dark",
    "workbench.activityBar.orientation": "vertical",
    "editor.minimap.enabled": true,
    "files.autoSave": "afterDelay",
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit",
            "source.organizeImports": "explicit"
        }
    },
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.experimental.showMoves": true,
    "diffEditor.experimental.useTrueInlineView": true,
    "git.autofetch": true,
    "jupyter.askForKernelRestart": false,
    "editor.largeFileOptimizations": false,
    "workbench.editorAssociations": {
        "*.md": "default",
        "*.markdown": "default",
        "*.csv": "default"
    },
    "js/ts.inlayHints.parameterNames.enabled": "all",
    "editor.multiCursorLimit": 50000,
    "workbench.editorLargeFileConfirmation": 25,
    "editor.unicodeHighlight.allowedLocales": {
        "tr": true
    },
    "redhat.telemetry.enabled": false,
    "[scss]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[markdown]": {
        "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
    },
    "[yaml]": {
        "editor.defaultFormatter": "redhat.vscode-yaml"
    },
    "diffEditor.maxComputationTime": 0,
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[typescript]": {
        "editor.defaultFormatter": "vscode.typescript-language-features"
    },
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb, bun.lock",
        "*.cs": "${capture}.designer.cs,${capture}.g.cs,${capture}.generated.cs,${capture}.run.json,${capture}.settings.json,${capture}.settings.*.json",
        "*.csproj": "${capture}.csproj.user",
        "*.json": "${capture}.Development.json",
        "*.cshtml": "${capture}.cshtml.cs,${capture}.cshtml.css",
        "*.razor": "${capture}.razor.cs,${capture}.razor.css",
        "*.resx": "${capture}.Designer.cs",
        "*.xaml": "${capture}.xaml.cs",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "notebook.editorOptionsCustomizations": {
        "editor.tabSize": 4,
        "editor.indentSize": 4,
        "editor.insertSpaces": true
    },
    "claudeCode.preferredLocation": "panel",
    "window.autoDetectColorScheme": false,
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "settingsSync.ignoredExtensions": [],
    "gitlens.launchpad.indicator.enabled": false,
    "remote.autoForwardPortsSource": "hybrid",
    "security.workspace.trust.untrustedFiles": "open"
}
